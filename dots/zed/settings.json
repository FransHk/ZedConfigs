{
  "enable_language_server": true,
  "unnecessary_code_fade": 0.2,
  "edit_predictions": {
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null,
    },
    "enabled_in_text_threads": false,
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "openai",
      "model": "gpt-4o",
    },
    "default_model": {
      "provider": "openai",
      "model": "gpt-4o",
    },
  },
  "show_edit_predictions": true,
  "base_keymap": "VSCode",
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 14,
  "buffer_font_size": 10.0,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Macchiato - No Italics",
    "dark": "Catppuccin Frappé - No Italics",
  },

  // From the ZED docs:
  // If a built-in language server is installed in the active virtual environment,
  // that binary will be used instead of Zed's private automatically-installed binary.
  // Check language server logs to verify if it uses the .venv version!
  "lsp": {
    "pyright": {
      "settings": {
        "python.analysis": {
          "diagnosticMode": "workspace",
          "typeCheckingMode": "standard",
        },
      },
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "logLevel": "debug",
        },
      },
    },
  },

  "languages": {
    "Rust": {
      "show_edit_predictions": false,
    },
    "Python": {
      "show_edit_predictions": true,
      "language_servers": ["pyright", "ruff"],
      "format_on_save": "on",
      "formatter": [
        { "code_action": "source.organizeImports.ruff" },
        {
          "language_server": {
            "name": "ruff",
          },
        },
      ],
    },
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
  },

  "buffer_font_family": "JetBrainsMonoNL Nerd Font",
  "ui_font_family": "JetBrainsMonoNL Nerd font",
}
